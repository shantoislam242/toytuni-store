# Supabase — copy this file to .env.local and fill in the values from
# Supabase → Project Settings → API. Do NOT commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storefront canonical origin (optional; overrides the default in config.ts).
# NEXT_PUBLIC_SITE_URL=https://toytuni-store.vercel.app

# Admin allowlist — comma-separated emails, case-insensitive. NOT a secret
# (an email address isn't a credential): both vars should hold the same list.
# ADMIN_EMAILS is read on the server and is the authoritative check
# (src/lib/auth/session.ts's getIsAdmin()). NEXT_PUBLIC_ADMIN_EMAILS is the
# same list exposed to the client bundle so the UI can reflect admin status
# without a round trip; never treat the client-side isAdmin as an
# authorization boundary — always re-check server-side before granting access.
ADMIN_EMAILS=
NEXT_PUBLIC_ADMIN_EMAILS=
